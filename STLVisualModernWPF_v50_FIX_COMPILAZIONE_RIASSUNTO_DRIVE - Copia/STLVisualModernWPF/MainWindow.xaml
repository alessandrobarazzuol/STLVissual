<Window x:Class="STLVisualModernWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="STL Visual Modern WPF - Alessandro Barazzuol"
        Width="1450" Height="850"
        MinWidth="1200" MinHeight="720"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU SINISTRO -->
        <Border Grid.Column="0" Background="#181818" BorderBrush="#333333" BorderThickness="0,0,1,0">
            <DockPanel Margin="10">
                <TextBlock DockPanel.Dock="Top" Text="STL Visual" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,6,0,12"/>
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnList" Style="{StaticResource MenuButton}" Content="std::list" Click="ContainerButton_Click"/>
                    <Button x:Name="BtnVector" Style="{StaticResource MenuButton}" Content="std::vector" Click="ContainerButton_Click"/>
                    <Button x:Name="BtnSet" Style="{StaticResource MenuButton}" Content="std::set" Click="ContainerButton_Click"/>
                    <Button x:Name="BtnStack" Style="{StaticResource MenuButton}" Content="std::stack" Click="ContainerButton_Click"/>
                    <Button x:Name="BtnQueue" Style="{StaticResource MenuButton}" Content="std::queue" Click="ContainerButton_Click"/>
                    <Button x:Name="BtnMap" Style="{StaticResource MenuButton}" Content="std::map" Click="ContainerButton_Click"/>

                    <!-- Pulsanti unificati richiesti: salvataggio completo + importazione completa -->
                    <Separator Margin="0,10,0,7" Background="#333333"/>
                    <Button x:Name="BtnSalvaTutto" Style="{StaticResource ActionButton}" Content="💾 SALVA" Click="SaveAll_Click" ToolTip="Salva guida, esercizi, riassunti e struttura cartelle; poi esporta su Google Drive/OAuth."/>
                    <Button x:Name="BtnImportaTutto" Style="{StaticResource ActionButton}" Content="📥 IMPORTA" Click="ImportAll_Click" ToolTip="Importa da Google Drive/OAuth o da file JSON guida, esercizi, riassunti e cartelle."/>
                    <Button x:Name="BtnCercaAggiornamenti" Style="{StaticResource ActionButton}" Content="⬇ AGGIORNAMENTI" Click="CheckGitHubUpdates_Click" ToolTip="Controlla le GitHub Releases, mostra dimensione del setup e installa la versione disponibile."/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
                    <Button Content="⚙ Impostazioni API" Style="{StaticResource ActionButton}" Click="ToggleApiPanel_Click"/>
                    <StackPanel x:Name="ApiPanel" Visibility="Collapsed" Margin="0,8,0,0">
                        <TextBlock Text="OpenRouter API Key" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="ApiPasswordBox" Background="#111827" Foreground="White" BorderBrush="#3E3E42" Padding="7"/>
                        <TextBox x:Name="ApiVisibleBox" Visibility="Collapsed"/>
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Salva API" Click="SaveApi_Click"/>
                            <Button Content="Mostra" Click="ShowApi_Click"/>
                            <Button Content="Carica OAuth Drive" Click="LoadGoogleCredentials_Click"/>
                        </WrapPanel>
                    </StackPanel>
                    <TextBlock Text="Copyright (C) Alessandro Barazzuol&#10;&#10;GUIDA RAPIDA&#10;• SALVA: salva guida, esercizi, riassunti, modifiche e struttura cartelle; poi esporta tutto su Drive.&#10;• IMPORTA: importa da Drive/OAuth o da file JSON tutto il database.&#10;• Shift + click: apre le caselle guida/consegna/codice/albero in popup grande.&#10;• OAuth Drive: carica credentials.json dalle impostazioni API.&#10;• OpenRouter: inserisci e salva la tua API Key per generare codice C++." Foreground="#777" FontSize="11" Margin="0,18,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENUTO -->
        <TabControl Grid.Column="1" Margin="12">
            <TabItem Header="Visualizzatore STL">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="185"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ContainerTitle" Grid.Column="0" Grid.Row="0" Text="std::list"
                               FontSize="27" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>

                    <UniformGrid x:Name="MethodsGrid" Grid.Column="0" Grid.Row="1" Columns="4" Margin="0,0,12,8"/>

                    <WrapPanel Grid.Column="0" Grid.Row="2" VerticalAlignment="Top" Margin="0,0,12,4">
                        <Button Style="{StaticResource GuideButton}" Content="Iteratori" Click="GuideIterators_Click"/>
                        <Button Style="{StaticResource GuideButton}" Content="Scorrimento" Click="GuideLoops_Click"/>
                        <Button Style="{StaticResource GuideButton}" Content="Accesso" Click="GuideAccess_Click"/>
                        <Button Style="{StaticResource GuideButton}" Content="Errori" Click="GuideErrors_Click"/>
                        <Button Style="{StaticResource GuideButton}" Content="Overload" Click="GuideOverloads_Click"/>
                        <Button Style="{StaticResource GuideButton}" Content="Costruttori" Click="GuideConstructors_Click"/>
                        <Button Style="{StaticResource GuideButton}" Background="#7C3AED" Content="DEF" Click="GuideDef_Click"/>
                        <Button Style="{StaticResource GuideButton}" Background="#DC2626" Foreground="White" FontWeight="Bold" Padding="8,5" MinWidth="86" MinHeight="30" FontSize="12" Content="Disegni" Click="Summary_Click"/>
                        
                    </WrapPanel>

                    <Border Grid.Column="0" Grid.Row="2" Margin="0,46,12,0" Background="#202124" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="8">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Overload disponibili del metodo selezionato" Foreground="#D1D5DB" FontWeight="SemiBold" Margin="4,0,0,6"/>
                            <WrapPanel Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <TextBlock Text="Posizione" Foreground="#9CA3AF" FontSize="11"/>
                                    <TextBox x:Name="OverloadPosBox" Width="65" Text="0"/>
                                </StackPanel>
                                <StackPanel Margin="4">
                                    <TextBlock Text="Valore" Foreground="#9CA3AF" FontSize="11"/>
                                    <TextBox x:Name="OverloadValueBox" Width="75" Text="10"/>
                                </StackPanel>
                                <StackPanel Margin="4">
                                    <TextBlock Text="Quantità" Foreground="#9CA3AF" FontSize="11"/>
                                    <TextBox x:Name="OverloadCountBox" Width="65" Text="2"/>
                                </StackPanel>
                                <StackPanel Margin="4">
                                    <TextBlock Text="Valori range" Foreground="#9CA3AF" FontSize="11"/>
                                    <TextBox x:Name="OverloadRangeBox" Width="145" Text="1,2,3"/>
                                </StackPanel>
                                <StackPanel Margin="4">
                                    <TextBlock Text="Chiave map" Foreground="#9CA3AF" FontSize="11"/>
                                    <TextBox x:Name="OverloadKeyBox" Width="75" Text="1"/>
                                </StackPanel>
                            </WrapPanel>
                            <ScrollViewer Height="75" VerticalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="OverloadActionsPanel"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="0" Grid.Row="2" Margin="0,220,12,0" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid MinWidth="820" MinHeight="310" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas x:Name="VisualCanvas" Width="820" Height="310" Margin="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <DockPanel Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <!-- Pulsanti vecchi rimossi: ora si usa SALVA / IMPORTA nel menu sinistro -->
                        <TextBox x:Name="GuideTextBox"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Segoe UI" FontSize="14"/>
                    </DockPanel>

                    <!-- OpenRouter -->
                    <Grid Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Margin="12,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Testo esercizio / consegna" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBox x:Name="ExerciseTextBox" Height="75" AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" Text="Scrivi un programma C++ che legga 10 numeri, li inserisca in un vector, li ordini e stampi il risultato."/>
                        </StackPanel>

                        <WrapPanel Grid.Row="1" Margin="0,6,0,8">
                            <Button Style="{StaticResource ActionButton}" Content="Genera C++" Click="GenerateCpp_Click"/>
                            <Button Content="📁 Apri cartella esercizi" Click="OpenExercisesFolder_Click"/>
                            <Button Content="📂 Carica esercizio" Click="LoadExercise_Click"/>
                            <Button Content="🔄 Aggiorna lista" Click="RefreshExercises_Click"/>
                            <Button Content="🗑 Elimina selezionato" Click="DeleteExercise_Click"/>
                        </WrapPanel>

                        <Border Grid.Row="2" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Esercizi salvati per cartelle" Foreground="#D1D5DB" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TreeView x:Name="ExerciseTree" Background="White" Foreground="Black" SelectedItemChanged="ExerciseTree_SelectedItemChanged" MouseDoubleClick="ExerciseTree_MouseDoubleClick"/>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="3" Background="#0B1020" BorderBrush="#334155" BorderThickness="1" CornerRadius="8">
                            <RichTextBox x:Name="GeneratedCodeBox" Margin="8" Background="#0B1020" Foreground="#D1D5DB"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="14"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         IsReadOnly="False" AcceptsTab="True" SpellCheck.IsEnabled="False" ToolTip="Qui puoi modificare o scrivere manualmente il codice C++ generato"/>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Compila C++">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="170"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Editor C++ - compilazione con g++ se installato nel computer"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <RichTextBox x:Name="CppEditorBox" Grid.Row="1"
                             FontFamily="Consolas" FontSize="14"
                             Background="#0B1020" Foreground="#D1D5DB"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             AcceptsTab="True" SpellCheck.IsEnabled="False"/>
                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <Button Style="{StaticResource ActionButton}" Content="Compila ed esegui" Click="CompileAndRun_Click"/>
                            <Button Content="Esempio C++" Click="CppExample_Click"/>
                            <Button Content="Salva sorgente" Click="SaveSource_Click"/>
                            <Button Content="Colora codice" Click="HighlightEditor_Click"/>
                        </StackPanel>
                        <TextBox x:Name="CompilerOutputBox" Margin="0,10,0,0" AcceptsReturn="True"
                                 FontFamily="Consolas" FontSize="13"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"/>
                    </DockPanel>
                </Grid>
            </TabItem>
        
            <TabItem Header="Albero binario">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="330"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Menu albero binario" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                            <TextBlock Text="Valore nodo" Foreground="#9CA3AF"/>
                            <TextBox x:Name="TreeValueBox" Text="10" Margin="0,4,0,8"/>
                            <Button Style="{StaticResource ActionButton}" Content="Inserisci nodo" Click="TreeInsert_Click"/>
                            <Button Content="Elimina valore" Click="TreeDelete_Click"/>
                            <Button Content="Crea albero random" Click="TreeRandom_Click"/>
                            <Button Content="Crea albero bilanciato" Click="TreeBalanced_Click"/>
                            <Button Content="Cancella albero" Click="TreeClear_Click"/>
                            <Separator Margin="0,12,0,12"/>
                            <Button Style="{StaticResource GuideButton}" Content="Visita Preorder" Click="TreePreorder_Click"/>
                            <Button Style="{StaticResource GuideButton}" Content="Visita Inorder" Click="TreeInorder_Click"/>
                            <Button Style="{StaticResource GuideButton}" Content="Visita Postorder" Click="TreePostorder_Click"/>
                            <WrapPanel Margin="0,6,0,6">
                                <Button Style="{StaticResource ActionButton}" Content="▶ Avanti visita" Click="TreeNextVisit_Click"/>
                                <Button Content="↺ Reset visita" Click="TreeResetVisit_Click"/>
                            </WrapPanel>
                            <Button Content="Conta valore" Click="TreeCount_Click"/>
                            <Button Content="Altezza / livello" Click="TreeHeight_Click"/>
                            <Separator Margin="0,12,0,12"/>
                            <TextBlock Text="Zoom albero" Foreground="#9CA3AF"/>
                            <WrapPanel>
                                <Button Content="Zoom +" Click="TreeZoomIn_Click"/>
                                <Button Content="Zoom -" Click="TreeZoomOut_Click"/>
                                <Button Content="Adatta" Click="TreeFit_Click"/>
                            </WrapPanel>
                            <Separator Margin="0,12,0,12"/>
                            <TextBlock Text="Random min/max/nodi" Foreground="#9CA3AF"/>
                            <WrapPanel>
                                <TextBox x:Name="TreeMinBox" Width="55" Text="0" Margin="2"/>
                                <TextBox x:Name="TreeMaxBox" Width="55" Text="40" Margin="2"/>
                                <TextBox x:Name="TreeCountBox" Width="55" Text="12" Margin="2"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Margin="10,0" Padding="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="TreeCanvas" Width="2000" Height="1100"/>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Background="#111827" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Risultato visite / guida" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                            <TextBox x:Name="TreeOutputBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Text="Qui appariranno le visite preorder, inorder, postorder e le informazioni sull'albero."/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>


            <TabItem Header="Debugger variabili">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="0.95*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="170"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Debugger didattico C++ - variabili passo passo"
                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>

                    <Border Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Background="#0B1020" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Codice sorgente" Foreground="#D1D5DB" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <RichTextBox x:Name="DebugCodeBox"
                                         Background="#0B1020" Foreground="#D1D5DB"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="14"
                                         AcceptsTab="True" SpellCheck.IsEnabled="False"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,10">
                        <WrapPanel Margin="0,0,0,8">
                            <Button Style="{StaticResource ActionButton}" Content="Avvia debugger" Click="DebugStart_Click"/>
                            <Button Content="▶ Procedi" Click="DebugNext_Click"/>
                            <Button Content="↺ Reset" Click="DebugReset_Click"/>
                            <Button Content="Esempio" Click="DebugExample_Click"/>
                            <Button Content="Copia da Compila C++" Click="DebugCopyFromEditor_Click"/>
                            <Button Content="Copia da soluzione" Click="DebugCopyFromGenerated_Click"/>
                        </WrapPanel>

                        <Border Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Variabili" Foreground="#D1D5DB" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="DebugVariablesBox" Height="250" AcceptsReturn="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="14"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         Text="Premi Avvia debugger, poi Procedi."/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="1" Grid.Row="2" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Passo corrente" Foreground="#D1D5DB" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox x:Name="DebugOutputBox" AcceptsReturn="True" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="13"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     Text="Qui comparirà la riga eseguita e come cambiano le variabili."/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="PDF Drive">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Grid.RowSpan="3" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,10,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="PDF su Google Drive" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock DockPanel.Dock="Top" Text="La scheda crea/legge la cartella PDF nel Drive OAuth e mostra sottocartelle e file PDF." Foreground="#CBD5E1" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Button DockPanel.Dock="Top" Content="🔄 Aggiorna PDF Drive" Style="{StaticResource ActionButton}" Click="RefreshDrivePdfTree_Click" Margin="0,0,0,10"/>
                            <TreeView x:Name="DrivePdfTree" SelectedItemChanged="DrivePdfTree_SelectedItemChanged"
                                      Background="#0B1220" Foreground="White" BorderBrush="#334155"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <TreeView.Resources>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="3,2"/>
                                    </Style>
                                </TreeView.Resources>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <DockPanel>
                            <TextBlock x:Name="PdfSelectedText" Text="Seleziona un PDF dall'albero." Foreground="#E5E7EB" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="Apri esterno" Click="OpenCurrentPdfExternal_Click" Margin="10,0,0,0" Padding="10,5"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="6">
                        <WebBrowser x:Name="PdfViewer"/>
                    </Border>

                    <TextBlock x:Name="PdfStatusText" Grid.Column="1" Grid.Row="2" Text="Pronto." Foreground="#94A3B8" FontSize="12" Margin="0,8,0,0"/>
                </Grid>
            </TabItem>


        </TabControl>
    </Grid>
</Window>
